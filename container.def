BootStrap: docker
From: nvidia/cuda:12.6.0-devel-ubuntu24.04

%environment
    LANG=en_US.UTF-8
    LC_ALL=en_US.UTF-8
    export PATH=/opt/venv/bin:$PATH

%post
    # Update and Upgrade base system
    export DEBIAN_FRONTEND=noninteractive
    apt-get -y update
    apt-get -y full-upgrade

    # Install locales
    apt-get install -y locales
    sed -i -e 's/# en_US.UTF-8 UTF-8/en_US.UTF-8 UTF-8/' /etc/locale.gen
    dpkg-reconfigure --frontend=noninteractive locales && update-locale LANG=en_US.UTF-8

    # Python + utilities
    apt-get install -y python3 python3-pip python3-dev python3-venv
    apt-get install -y python3-setuptools git wget curl vim bc man screen nano

    # System libs for VisPy fonts + Qt runtime deps
    apt-get install -y --no-install-recommends fontconfig libfontconfig1 libfreetype6 libc-bin

    apt-get install -y --no-install-recommends \
        libxcb-cursor0 \
        libxkbcommon0 libxkbcommon-x11-0 \
        libegl1 libgl1 \
        libxcb1 libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-randr0 \
        libxcb-render0 libxcb-render-util0 libxcb-shape0 libxcb-shm0 libxcb-sync1 \
        libxcb-xfixes0 libxcb-xinerama0 libxcb-xkb1 \
        libx11-6 libxext6 libxrender1 libxi6 libxrandr2 libxfixes3 \
        libglib2.0-0 libdbus-1-3

    # D-Bus + machine-id fix (prevents Qt/DBus aborts in containers)
    apt-get install -y --no-install-recommends dbus
    rm -f /etc/machine-id /var/lib/dbus/machine-id
    dbus-uuidgen --ensure=/etc/machine-id
    dbus-uuidgen --ensure=/var/lib/dbus/machine-id

    # Refresh dynamic linker cache
    ldconfig

    # Python virtual environment
    python3 -m venv /opt/venv

    # Python dependencies

    /opt/venv/bin/pip install --no-cache-dir numpy==2.4.2
    /opt/venv/bin/pip install --no-cache-dir torch==2.7.1 --index-url https://download.pytorch.org/whl/cu126
    /opt/venv/bin/pip install --no-cache-dir timm==1.0.19
    /opt/venv/bin/pip install --no-cache-dir tifffile==2026.1.28
    /opt/venv/bin/pip install --no-cache-dir h5py==3.15.1
    /opt/venv/bin/pip install --no-cache-dir zarr==3.1.5
    /opt/venv/bin/pip install --no-cache-dir PySide6==6.10.2
    /opt/venv/bin/pip install --no-cache-dir vispy==0.16.1

    # Cleanup
    apt-get autoremove -y --purge
    apt-get autoclean -y
    rm -rf /var/lib/apt/lists/*

%runscript
    exec "$@"

